    "check": "npm run verify:mock",
    "postcheck": "node tools/verify-readonly.mjs --self-check"
  },
  "keywords": [
    "openclaw",
    "local-ai",
    "ai-agents",
    "runtime-reliability",
    "incident-response",
    "state-repair",
    "session-store",
    "rollback-safety",
    "redaction"
  ],
  "engines": {
    "node": ">=20"
  }
}
