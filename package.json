{
  "name": "openclaw-runtime-stabilizer",
  "version": "0.2.1",
  "description": "Public reliability case study and read-only verifier for OpenClaw local AI agent runtime stabilization.",
  "type": "module",
  "private": false,
  "license": "Apache-2.0",
  "author": "Moustafa Elkhamesey",
  "homepage": "https://github.com/melkhamesey2/openclaw-runtime-stabilizer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/melkhamesey2/openclaw-runtime-stabilizer.git"
  },
  "bugs": {
    "url": "https://github.com/melkhamesey2/openclaw-runtime-stabilizer/issues"
  },
  "scripts": {
    "verify": "node tools/verify-readonly.mjs",
    "verify:mock": "npm run verify -- examples/mock-session-store",
